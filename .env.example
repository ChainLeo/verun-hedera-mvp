## Verun Hedera MVP — environment
##
## DO NOT commit real secrets to this file. It is checked into git as a
## template only. Real keys live in `.env` (gitignored) on each developer
## machine and in Vercel project env vars in production.
##
## To populate your local `.env`:
##   1) cp .env.example .env
##   2) Create a testnet account at https://portal.hedera.com (it ships
##      pre-funded with 1000 HBAR) and copy the Account ID + DER private key
##      into HEDERA_OPERATOR_ID + HEDERA_OPERATOR_KEY below.
##   3) npm run create-topic     (creates a dedicated HCS topic for the
##      protocol and prints HEDERA_TOPIC_ID — paste it into .env)
##   4) npm run check            (sanity-check operator + topic)
##   5) npm run verify           (5-tick lifecycle on real Testnet)

# Required: operator account ID (e.g., 0.0.123456) — the protocol "issuer".
HEDERA_OPERATOR_ID=0.0.PASTE_ACCOUNT_ID_HERE

# Required: operator DER-encoded private key (302e0201...).
# ED25519 keys are recommended.
HEDERA_OPERATOR_KEY=302e0201_PASTE_DER_PRIVATE_KEY_HERE

# Required after `npm run create-topic`: dedicated HCS topic ID (e.g., 0.0.789).
# All vtrust-mint / vtrust-revoke / verun-eval messages are submitted here.
HEDERA_TOPIC_ID=0.0.PASTE_TOPIC_ID_HERE

# Hedera network: testnet | previewnet | mainnet (testnet by default).
HEDERA_NETWORK=testnet

# Mirror Node REST endpoint (Testnet by default).
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# How many recent HCS messages to scan for the SBT registry.
SBT_SCAN_LIMIT=200

# Local express port (only for `npm run api`, not Vercel).
PORT=3010

## ─── x402 / Stablecoin Studio integration ─────────────────────────
##
## /api/x402/evaluate returns HTTP 402 with paymentRequirements for two
## schemes (USDC + HBAR) routed via the Hedera Official x402 Facilitator.

# Hedera Official x402 Facilitator URL. Leave unset to run in `simulate`
# mode (the demo terminal will still produce a clean transcript with a
# plausible HashScan testnet txid for the settlement step).
# X402_FACILITATOR_URL=https://x402.hedera.com

# Per-evaluation price in human units. Defaults: 0.005 USDC / 0.005 HBAR.
# X402_PRICE_USDC=0.005
# X402_PRICE_HBAR=0.005

# Network kind for payment scheme selection: testnet | mainnet.
# Picks the matching USDC token ID (testnet 0.0.429274 / mainnet 0.0.456858).
X402_NETWORK=testnet

# Optional override of the protocol payTo address. Defaults to HEDERA_OPERATOR_ID.
# HEDERA_PAY_TO=0.0.PASTE_PAY_TO_HERE
